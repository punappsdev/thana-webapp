// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum AdminActivityAction {
  CREATE
  UPDATE
  PUBLISH
  UNPUBLISH
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  UPLOAD
}

enum MediaKind {
  IMAGE
  PDF
}

model AdminUser {
  id                String         @id @default(cuid())
  email             String         @unique
  name              String
  passwordHash      String
  active            Boolean        @default(true)
  passwordChangedAt DateTime       @default(now())
  sessions          AdminSession[]
  activities        ActivityLog[]
  media             MediaAsset[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([active])
}

model AdminSession {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress String?   @db.VarChar(64)
  userAgent String?   @db.VarChar(512)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AdminLoginAttempt {
  id        Int      @id @default(autoincrement())
  email     String   @db.VarChar(191)
  ipAddress String   @db.VarChar(64)
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, ipAddress, createdAt])
  @@index([createdAt])
}

model ActivityLog {
  id         Int                 @id @default(autoincrement())
  adminId    String?
  admin      AdminUser?          @relation(fields: [adminId], references: [id], onDelete: SetNull)
  action     AdminActivityAction
  entityType String              @db.VarChar(64)
  entityId   String?             @db.VarChar(191)
  label      String?             @db.VarChar(255)
  metadata   Json?
  createdAt  DateTime            @default(now())

  @@index([adminId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model MediaAsset {
  id           String     @id @default(cuid())
  path         String     @unique @db.VarChar(512)
  url          String     @unique @db.VarChar(768)
  originalName String     @db.VarChar(255)
  mimeType     String     @db.VarChar(100)
  kind         MediaKind
  size         Int
  width        Int?
  height       Int?
  uploadedById String?
  uploadedBy   AdminUser? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  @@index([kind])
  @@index([uploadedById])
  @@index([createdAt])
}

model ArticleCategory {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  nameTh    String
  nameEn    String
  articles  Article[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
}

model Article {
  id         Int     @id @default(autoincrement())
  slug       String  @unique
  titleTh    String
  titleEn    String
  contentTh  String  @db.Text
  contentEn  String  @db.Text
  excerptTh  String? @db.Text
  excerptEn  String? @db.Text
  coverImage String?
  published  Boolean @default(false)

  // Relations
  articleCategoryId Int?
  category          ArticleCategory? @relation(fields: [articleCategoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([articleCategoryId])
}

model Work {
  id            Int     @id @default(autoincrement())
  slug          String  @unique
  titleTh       String
  titleEn       String
  descriptionTh String? @db.Text
  descriptionEn String? @db.Text
  coverImage    String?
  published     Boolean @default(false)

  // Relations — shares the Category table with Product
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([categoryId])
}

model News {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  titleTh    String
  titleEn    String
  contentTh  String   @db.Text
  contentEn  String   @db.Text
  excerptTh  String?  @db.Text
  excerptEn  String?  @db.Text
  coverImage String?
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([slug])
}

model Promotion {
  id         Int       @id @default(autoincrement())
  slug       String    @unique
  titleTh    String
  titleEn    String
  contentTh  String    @db.Text
  contentEn  String    @db.Text
  excerptTh  String?   @db.Text
  excerptEn  String?   @db.Text
  coverImage String?
  published  Boolean   @default(false)
  startDate  DateTime?
  endDate    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([slug])
}

// ---------------------------------------------------------------------------
// Categories — shared by Product and Work (portfolio)
// ---------------------------------------------------------------------------

model Category {
  id            Int     @id @default(autoincrement())
  slug          String  @unique
  nameTh        String
  nameEn        String
  descriptionTh String? @db.Text
  descriptionEn String? @db.Text
  coverImage    String?
  sortOrder     Int     @default(0)
  published     Boolean @default(true)

  subCategories SubCategory[]
  products      Product[]
  works         Work[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model SubCategory {
  id         Int     @id @default(autoincrement())
  slug       String
  nameTh     String
  nameEn     String
  coverImage String?
  sortOrder  Int     @default(0)
  published  Boolean @default(true)

  // Relations
  categoryId Int
  category   Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  products   Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Slug only needs to be unique within its parent category
  @@unique([categoryId, slug])
  @@index([categoryId])
}

// ---------------------------------------------------------------------------
// Products
// ---------------------------------------------------------------------------

model Brand {
  id         Int       @id @default(autoincrement())
  slug       String    @unique
  name       String
  logo       String?
  websiteUrl String?
  products   Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

/// หน่วยสินค้า เช่น แผ่น, ชิ้น, ม้วน
model ProductUnit {
  id       Int       @id @default(autoincrement())
  code     String    @unique
  nameTh   String
  nameEn   String
  products Product[]
}

/// หน่วยจำหน่าย เช่น ราคาต่อแผ่น, ราคาต่อคู่, ราคาต่อแพ็ค
model PricingUnit {
  id       Int       @id @default(autoincrement())
  code     String    @unique
  nameTh   String
  nameEn   String
  products Product[]
}

model Product {
  id            Int     @id @default(autoincrement())
  slug          String  @unique
  sku           String  @unique
  nameTh        String
  nameEn        String
  descriptionTh String? @db.Text
  descriptionEn String? @db.Text
  usageGuideTh  String? @db.Text
  usageGuideEn  String? @db.Text

  coverImage String?
  catalogPdf String?

  basePrice Decimal? @db.Decimal(12, 2)
  currency  String   @default("THB")

  featured  Boolean @default(false)
  published Boolean @default(false)
  sortOrder Int     @default(0)

  // Relations
  unitId        Int?
  unit          ProductUnit? @relation(fields: [unitId], references: [id], onDelete: SetNull)
  pricingUnitId Int?
  pricingUnit   PricingUnit? @relation(fields: [pricingUnitId], references: [id], onDelete: SetNull)
  brandId       Int?
  brand         Brand?       @relation(fields: [brandId], references: [id], onDelete: SetNull)
  categoryId    Int?
  category      Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subCategoryId Int?
  subCategory   SubCategory? @relation(fields: [subCategoryId], references: [id], onDelete: SetNull)

  images         ProductImage[]
  variants       ProductVariant[]
  attributes     ProductAttribute[]
  attributeLinks ProductAttributeValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([subCategoryId])
  @@index([brandId])
  @@index([unitId])
  @@index([pricingUnitId])
  @@index([published, featured])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  url       String
  altTh     String?
  altEn     String?
  sortOrder Int     @default(0)

  // Relations
  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

enum AttributeInputType {
  SELECT
  COLOR
  NUMBER
  TEXT
}

/// คุณสมบัติสินค้า เช่น ความหนา, ขนาด, สี, ประเภทขอบ
model Attribute {
  id        Int                @id @default(autoincrement())
  slug      String             @unique
  nameTh    String
  nameEn    String
  unit      String?
  inputType AttributeInputType @default(SELECT)
  sortOrder Int                @default(0)

  values   AttributeValue[]
  products ProductAttribute[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AttributeValue {
  id           Int      @id @default(autoincrement())
  slug         String
  valueTh      String
  valueEn      String
  colorHex     String?
  numericValue Decimal? @db.Decimal(12, 3)
  sortOrder    Int      @default(0)

  // Relations
  attributeId Int
  attribute   Attribute               @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  products    ProductAttributeValue[]
  variants    VariantAttributeValue[]

  @@unique([attributeId, slug])
  @@index([attributeId])
}

/// คุณลักษณะที่สินค้าตัวนี้ใช้ — แต่ละสินค้ากำหนดชุดของตัวเองได้อิสระ
/// isVariantAxis = true คือคุณลักษณะที่ลูกค้าเลือกได้และทำให้ราคาต่างกัน
/// (ใช้ generate variants); false คือแสดงในตารางข้อมูลจำเพาะอย่างเดียว
model ProductAttribute {
  id            Int     @id @default(autoincrement())
  isVariantAxis Boolean @default(false)
  sortOrder     Int     @default(0)

  // Relations
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeId Int
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeId])
  @@index([attributeId])
}

/// ค่าคุณสมบัติที่สินค้าตัวนี้มี ใช้กรองในหน้า listing โดยไม่ต้อง join variant
model ProductAttributeValue {
  id               Int            @id @default(autoincrement())
  productId        Int
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValueId Int
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([productId, attributeValueId])
  @@index([attributeValueId])
}

/// 1 variant = 1 ชุดคุณสมบัติที่ลูกค้าเลือก มีราคา/สต็อกของตัวเอง
model ProductVariant {
  id           Int      @id @default(autoincrement())
  sku          String?  @unique
  price        Decimal  @db.Decimal(12, 2)
  /// Reserved for a future promotion feature — not read or written anywhere yet.
  /// There is no discount system, so no "before" price is collected or shown.
  comparePrice Decimal? @db.Decimal(12, 2)
  image        String?
  /// Reserved for a future stock feature — not read or written anywhere yet.
  /// Products are quote-request only, so no stock level is shown to customers.
  stockQty     Int?
  /// Whether this combination is offered at all. Drives the greyed-out options
  /// in the variant picker — unrelated to stock levels.
  isAvailable  Boolean  @default(true)
  isDefault    Boolean  @default(false)
  sortOrder    Int      @default(0)

  // Relations
  productId       Int
  product         Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValues VariantAttributeValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model VariantAttributeValue {
  id               Int            @id @default(autoincrement())
  variantId        Int
  variant          ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attributeValueId Int
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeValueId])
  @@index([attributeValueId])
}
